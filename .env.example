# ── Claude backend ────────────────────────────────────────────────────────────
# Before June 15 2026: use a temporary Anthropic API key for development.
# After June 15 2026: delete ANTHROPIC_API_KEY and set USE_CLAUDE_SUBSCRIPTION=true
# to authenticate via your Claude Code OAuth session (no separate billing card).
ANTHROPIC_API_KEY=sk-ant-...
USE_CLAUDE_SUBSCRIPTION=false        # flip to true on June 15

# ── GitHub Copilot / GitHub Models backend ────────────────────────────────────
# A GitHub Personal Access Token with the "models:read" scope gives access to
# the GitHub Models API (OpenAI-compatible endpoint) included in your Copilot plan.
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_...

# ── Ollama ────────────────────────────────────────────────────────────────────
# Default: local Ollama server. Change if you run Ollama on a different host.
OLLAMA_BASE_URL=http://localhost:11434

# ── Budget limits (optional overrides — defaults come from routing.yaml) ──────
# CLAUDE_MONTHLY_BUDGET_USD=20.0
# COPILOT_MONTHLY_PREMIUM_REQUESTS=300

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=data/autopilot.db
